{
  "$schema": "https://claude.ai/schema/settings.json",

  "model": "claude-sonnet-4-6",

  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(public/**)",
      "Write(sanity/**)",
      "Write(*.json)",
      "Write(*.md)",
      "Write(*.env.example)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash.sh"
          }
        ]
      }
    ]
  },

  "env": {
    "NODE_ENV": "development",
    "NEXT_TELEMETRY_DISABLED": "1"
  },

  "includeCoAuthoredBy": true
}
